# ─────────────────────────────────────────────────────────────────────────────
# WEPL Mobile — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# All EXPO_PUBLIC_ vars are bundled into the JS bundle — do NOT put secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# API base URL (defaults to localhost:8000 in development)
EXPO_PUBLIC_API_URL=http://localhost:8000

# Sentry DSN — get from sentry.io → Project Settings → Client Keys
# Leave blank to disable error reporting (safe for local dev)
EXPO_PUBLIC_SENTRY_DSN=
