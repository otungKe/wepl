# ─────────────────────────────────────────────────────────────────────────────
# WEPL Mobile — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# All EXPO_PUBLIC_ vars are bundled into the JS bundle — do NOT put secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# API base URL. MUST end with /api/ (axios baseURL in constants/config.ts
# includes the suffix). Leave unset in dev to auto-derive the host from the
# Expo connection (works for emulator + physical device); set it to override.
#
#   Local backend on this machine (web):   http://localhost:8000/api/
#   Local backend from a physical device:  http://<your-LAN-IP>:8000/api/
#   Live backend:                          https://wepl-api.onrender.com/api/
EXPO_PUBLIC_API_URL=https://wepl-api.onrender.com/api/

# WebSocket base URL (no trailing path). Use wss:// for any remote host.
EXPO_PUBLIC_WS_URL=wss://wepl-api.onrender.com

# Sentry DSN — get from sentry.io → Project Settings → Client Keys
# Leave blank to disable error reporting (safe for local dev)
EXPO_PUBLIC_SENTRY_DSN=
