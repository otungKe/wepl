# ─────────────────────────────────────────────────────────────────────────────
# WEPL Backend — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=replace-me-with-a-long-random-string

# Sentry — error tracking (get DSN from sentry.io → Project Settings → Client Keys)
# Leave blank to disable. Set in production; optional in development.
SENTRY_DSN=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL for all environments — never use SQLite)
DB_NAME=wepl
DB_USER=wepl
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# M-Pesa / Daraja API (Safaricom)
# Sandbox credentials: https://developer.safaricom.co.ke
# Production credentials: obtained after Safaricom go-live approval
# ─────────────────────────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=your_sandbox_consumer_key
MPESA_CONSUMER_SECRET=your_sandbox_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_sandbox_passkey
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CALLBACK_URL=https://your-ngrok-or-domain.com/api/mpesa/stk/callback/

# M-Pesa B2C (welfare fund disbursements)
MPESA_B2C_INITIATOR_NAME=testapi
MPESA_B2C_SECURITY_CREDENTIAL=your_b2c_security_credential
MPESA_B2C_RESULT_URL=https://your-ngrok-or-domain.com/api/mpesa/b2c/result/
MPESA_B2C_TIMEOUT_URL=https://your-ngrok-or-domain.com/api/mpesa/b2c/timeout/

# ─────────────────────────────────────────────────────────────────────────────
# SMS (Africa's Talking — for OTP delivery)
# Sign up at: https://account.africastalking.com
# ─────────────────────────────────────────────────────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=WEPL
